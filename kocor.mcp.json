{
  "mcpServers": {
    "fs": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "env": {}
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "bing-search": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "bing-cn-mcp"
      ]
    }
  },

  "tool_output": {
    "max_bytes": 50000,
    "max_lines": 2000,
    "max_line_length": 2000
  },

  "permissions": {
    "fs": {
      "safe": ["mcp_fs_read_file", "mcp_fs_read_text_file"],
      "dangerous": ["mcp_fs_write_file"]
    },
    "fetch": {
      "safe": ["mcp_fetch_fetch"]
    },
    "bing-search": {
      "safe": ["mcp_bing_search_bing_search", "mcp_bing_search_crawl_webpage"]
    }
  }
}