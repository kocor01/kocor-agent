# Kocor Agent 环境变量
# 复制为 .env 并填入你的 API Key

KOCOR_PROVIDER=openai          # 可选: openai | anthropic

# OpenAI 配置
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=http://0.0.0.0:8081  # 兼容端点（可选）

# Anthropic 配置
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_BASE_URL=http://0.0.0.0:8081  # 兼容端点（可选）

KOCOR_MAX_ITERATIONS=20        # Agent 最大迭代次数
KOCOR_TIMEOUT=30               # 工具执行超时（秒）
KOCOR_MCP_CONFIG=kocor.mcp.json  # MCP 服务器配置文件路径（可选，默认 kocor.mcp.json）
KOCOR_SKILLS_CONFIG=kocor.skills.json  # Skill 配置文件路径（可选，默认 kocor.skills.json）
KOCOR_SKILLS_DIR=.agents/skills              # Skill 安装目录路径（可选，默认 .agents/skills）
KOCOR_MEMORY_DIR=.kocor/memories            # 上下文记忆目录（可选，默认为空表示不使用文件记忆）
KOCOR_PROJECT_INSTRUCTIONS_PATH=KOCOR.md    # 项目指令文件路径（可选，默认 KOCOR.md）
KOCOR_CONTEXT_STRATEGY=default              # 上下文策略: default | sliding | aggressive
KOCOR_CONTEXT_MAX_TOKENS=200000             # 上下文窗口上限
KOCOR_CONTEXT_SUMMARY_THRESHOLD=0.70        # 摘要触发阈值（0~1）
KOCOR_CONTEXT_TRUNCATE_THRESHOLD=0.90       # 截断触发阈值（0~1）
KOCOR_PRESERVE_ROUNDS=3                     # 滑动窗口保留完整轮次数
